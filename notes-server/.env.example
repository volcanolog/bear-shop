# =====================================================================
# .env.example — шаблон переменных окружения для notes-server.
# Скопируйте в .env и подставьте свои значения.
# Реальный .env закоммичивать НЕЛЬЗЯ — он в .gitignore.
# =====================================================================

# Порт, на котором будет работать сервер.
PORT=3001

# VAPID-ключи для отправки Web Push. Сгенерировать: `npm run vapid`.
# Публичный ключ передаётся клиенту через GET /vapidPublicKey.
# Приватный должен оставаться ТОЛЬКО на сервере.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Subject — обязательное поле в VAPID. Браузеры/push-сервисы могут связаться
# с этим адресом, если push-уведомления вызывают проблемы. Допустимо
# email (mailto:) или URL.
VAPID_SUBJECT=mailto:dev@notes-app.local
