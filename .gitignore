node_modules/

# TLS-сертификаты для локального HTTPS (практика 15).
# Генерируются индивидуально через mkcert/openssl и НЕ должны попадать в репозиторий:
# приватный ключ — это секрет, а сертификат на localhost у каждого свой.
*.pem
*.key
*.crt

# Переменные окружения (практика 16): VAPID-ключи и прочие секреты.
# Приватный VAPID-ключ — это пароль вашего сервера для push-сервисов:
# попадание в репозиторий = любой может слать push от вашего имени.
.env
.env.new
.env.local
.env.*.local
